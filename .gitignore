# 환경변수 — API Key 포함. 절대 GitHub에 올리지 않는다.
# (.env.example / .env.production.example 같은 견본만 커밋 허용)

.env
.env.*
!.env.example
!.env.production.example



# Python 실행 중 생기는 임시 파일들

__pycache__/

*.pyc

*.pyo

.venv/

venv/



# ChromaDB가 자동으로 만드는 폴더 (재생성 가능)

backend/chroma_db/



# 데이터베이스 파일

*.db



# 전처리 생성물 (preprocess.py로 재생성 가능)
# ※ rag_documents.json은 Render 배포 시 인덱스 재생성 소스로 필요하므로 커밋한다.
#    (chroma_db는 재생성물이라 계속 제외)



# 프론트엔드 패키지 폴더 (용량이 매우 크므로 업로드 제외)

node_modules/

dist/



# 운영체제가 자동으로 만드는 파일

.DS_Store

Thumbs.db


