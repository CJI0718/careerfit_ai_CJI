# 이 파일(.env.example)만 Git에 올리고, 실제 값이 담긴 .env는 절대 커밋하지 않는다.
# 사용법: 이 파일을 복사해 .env로 만들고 값을 채운다.  (예: cp .env.example .env)

# Gemini API Key (필수) — https://aistudio.google.com/apikey 에서 발급
GEMINI_API_KEY=your_gemini_api_key_here

# 답변 생성 LLM 모델 (기본: Gemini). mistral-... 로 바꾸면 Mistral 사용
LLM_MODEL=gemini-2.5-flash-lite

# true이면 실제 LLM 호출 없이 목업 응답 반환 (개발·비용 절약용)
MOCK_MODE=false

# CORS 허용 프론트엔드 origin (쉼표로 여러 개).
# 로컬 기본값(localhost:5173 등)은 코드에 이미 포함돼 있으니, 배포 시 Render 프론트 URL을 추가한다.
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend-service.onrender.com

# (선택) Mistral 사용 시
# MISTRAL_API_KEY=your_mistral_api_key_here
